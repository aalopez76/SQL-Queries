# sqlfluff configuration for sql-analytics-portfolio
# Aligned with configs/thresholds.yaml (query_quality).
[sqlfluff]
dialect = sqlite
max_line_length = 120
# Excluded rules: noise for an analytics portfolio (not real errors).
#  - RF02/RF03: require qualifying columns with their table in every join (verbose here).
#  - AM04: forbids SELECT * without a known schema (we use it in descriptive exploration).
#  - ST06: orders the SELECT columns by type (would rewrite queries unnecessarily).
# Note: CP02 (capitalisation.identifiers) is excluded because the classicmodels schema uses
# camelCase identifiers (customerNumber, orderNumber, ...) that we cannot rename.
exclude_rules = references.qualification, references.consistent, ambiguous.column_count, structure.column_order, capitalisation.identifiers

[sqlfluff:indentation]
indent_unit = space
tab_space_size = 4

# SQL keywords in UPPERCASE (the project's require_uppercase_keywords rule).
[sqlfluff:rules:capitalisation.keywords]
capitalisation_policy = upper

[sqlfluff:rules:capitalisation.functions]
extended_capitalisation_policy = upper

[sqlfluff:rules:capitalisation.literals]
capitalisation_policy = upper
